# Ollama (OpenAI-compatible API on Windows)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_JUDGE_MODEL=qwen2.5:3b-instruct

# RAGE LLM routing (same endpoint as Ollama)
RAGE_LLM_BASE_URL=http://localhost:11434/v1
RAGE_LLM_API_KEY=ollama
RAGE_LLM_MODEL=qwen2.5:7b-instruct
RAGE_USE_LLM_JUDGE=1

# Embeddings: offline TF-IDF (no large downloads)
RAGE_EMBEDDER=tfidf
