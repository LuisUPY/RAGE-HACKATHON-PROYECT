# RAGE — NVIDIA NIM configuration
#
# 1. Create a free account at https://build.nvidia.com
# 2. Generate your API key from the dashboard (nvapi-...)
# 3. Copy this file: cp .env.example .env
# 4. Fill in your keys below, then: source .env
#
# Or set directly in your shell:
#   export RAGE_LLM_API_KEY=nvapi-...
#   export RAGE_JUDGE_API_KEY=nvapi-...

# --- Main assistant: Llama 3.3 70B ---
RAGE_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
RAGE_LLM_API_KEY=nvapi-...
RAGE_LLM_MODEL=meta/llama-3.3-70b-instruct

# --- Judge (Layer 3): Nemotron Nano 8B ---
# Lightweight model — only called when semantic drift is detected.
# Can use the same key as the main model.
RAGE_JUDGE_BASE_URL=https://integrate.api.nvidia.com/v1
RAGE_JUDGE_API_KEY=nvapi-...
RAGE_JUDGE_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
RAGE_USE_LLM_JUDGE=1

# --- Embeddings: offline TF-IDF (no extra downloads required) ---
RAGE_EMBEDDER=tfidf
