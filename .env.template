# =============================================================================
# RAGE — configuración opcional (URLs y modelos; las API keys NO van aquí)
# =============================================================================
#
# PASOS:
#   1. Opcional: ./scripts/setup-env.sh  (crea .env sin secretos)
#   2. Ejecuta un comando en vivo, p. ej. ./scripts/run-support-chat.sh
#   3. Pega tu clave cuando el programa te la pida (solo esa sesión)
#
# Obtener clave NVIDIA gratis: https://build.nvidia.com → API Keys
#
# =============================================================================

RAGE_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
RAGE_LLM_MODEL=meta/llama-3.3-70b-instruct

RAGE_JUDGE_BASE_URL=https://integrate.api.nvidia.com/v1
RAGE_JUDGE_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
RAGE_USE_LLM_JUDGE=1

RAGE_EMBEDDER=tfidf

# --- Alternativa OpenAI (opcional — elige OpenAI en el prompt interactivo) ---
