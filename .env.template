# =============================================================================
# RAGE — LIENZO DE CONFIGURACIÓN (copia este archivo a .env y pega tu clave)
# =============================================================================
#
# PASOS:
#   1. Ejecuta:  ./scripts/setup-env.sh
#      (crea .env a partir de este archivo)
#   2. Abre .env con el editor que quieras (VS Code, Notepad, nano…)
#   3. Sustituye SOLO la línea PEGAR_AQUI... por tu clave nvapi- de NVIDIA
#   4. Guarda y lanza:  ./scripts/run-support-chat.sh
#
# Obtener clave gratis: https://build.nvidia.com  →  menú API Keys
# La clave suele verse así:  nvapi-xxxxxxxxxxxxxxxxxxxxxxxx
#
# =============================================================================

# >>> PEGA AQUÍ TU CLAVE (una sola vez — el resto se rellena solo) <<<
RAGE_NVIDIA_API_KEY=PEGAR_AQUI_TU_CLAVE_NVAPI

# =============================================================================
# Lo de abajo ya está listo — no hace falta tocarlo
# =============================================================================

RAGE_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
RAGE_LLM_MODEL=meta/llama-3.3-70b-instruct

RAGE_JUDGE_BASE_URL=https://integrate.api.nvidia.com/v1
RAGE_JUDGE_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
RAGE_USE_LLM_JUDGE=1

RAGE_EMBEDDER=tfidf

# --- Alternativa OpenAI (opcional — comenta lo de NVIDIA y descomenta esto) ---
# OPENAI_API_KEY=PEGAR_AQUI_TU_CLAVE_SK
# RAGE_USE_LLM_JUDGE=1
