# NVIDIA NIM profile — Llama 3.3 70B (asistente) + Nemotron Nano 8B (juez L3)
#
# Requisitos:
#   export NVIDIA_API_KEY=nvapi-...   (desde build.nvidia.com)
#
# El juez solo se invoca cuando Layer 3 detecta drift semántico alto.
# En conversación normal no se realiza ninguna llamada al juez.

# --- Asistente principal ---
RAGE_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
RAGE_LLM_API_KEY=${NVIDIA_API_KEY}
RAGE_LLM_MODEL=meta/llama-3.3-70b-instruct

# --- Juez L3 (modelo pequeño — clasifica YES/NO en escalaciones) ---
RAGE_JUDGE_BASE_URL=https://integrate.api.nvidia.com/v1
RAGE_JUDGE_API_KEY=${NVIDIA_API_KEY}
RAGE_JUDGE_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
RAGE_USE_LLM_JUDGE=1

# --- Embeddings offline (sin descargas adicionales) ---
RAGE_EMBEDDER=tfidf
